{
  "name": "stockmachine-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli": "^20.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@shopify/react-native-skia": "2.6.2",
    "@stripe/stripe-react-native": "0.64.0",
    "axios": "^1.18.1",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.1",
    "expo-image-picker": "^57.0.5",
    "expo-intent-launcher": "~57.0.1",
    "expo-secure-store": "^57.0.1",
    "expo-status-bar": "~57.0.1",
    "i18next": "^26.3.6",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-i18next": "^17.0.9",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "tailwindcss": "^3.4.19",
    "victory-native": "^41.26.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^57.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.2",
    "msw": "^2.15.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider expo start",
    "android": "NODE_OPTIONS=--openssl-legacy-provider expo start --android",
    "prebuild": "npx expo prebuild --platform android",
    "build-android": "cd android && ./gradlew --stop && ./gradlew assembleRelease --no-daemon",
    "build-android:debug": "cd android && ./gradlew --stop && ./gradlew assembleDebug --no-daemon",
    "ios": "NODE_OPTIONS=--openssl-legacy-provider expo start --ios",
    "web": "NODE_OPTIONS=--openssl-legacy-provider expo start --web",
    "test": "jest --watchAll=false --passWithNoTests",
    "test:watch": "jest --watchAll"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./src/test-utils/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@api/(.*)$": "<rootDir>/src/api/$1",
      "^@constants/(.*)$": "<rootDir>/src/constants/$1",
      "^@i18n/(.*)$": "<rootDir>/src/i18n/$1",
      "^@navigation/(.*)$": "<rootDir>/src/navigation/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@features/(.*)$": "<rootDir>/src/features/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|victory-native|nativewind)"
    ]
  },
  "private": true,
  "allowScripts": {
    "msw@2.15.0": true,
    "@shopify/react-native-skia@2.6.2": true
  }
}
